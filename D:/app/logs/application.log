nformación de su interés.</td></tr></table>, codUsremisor=null, indTexto=1, codUsuario=20559577627, nombUsuario=null, indEstado=null, fecEnvio=null, fecLectura=null, fecEliminado=null, fecVigencia=null, tipoDestino=0, objDestino=null, listAttach=[], archivoAdjunto=false, url=/cl-ti-iagenerador/gendocS01Alias?accion=genhtml)
